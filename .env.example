# Riot API key. Do not commit a real key.
RIOT_API_KEY=RGAPI-...

# Local mode: leave DATABASE_URL empty and the app uses data/inhouse_balancer.sqlite.
# Production mode: set a PostgreSQL connection URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Optional simple admin gate for future deployment hardening.
ADMIN_PASSWORD=
